# App
APP_ENV=development
APP_NAME=Printo KZ Backend
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# Database
DATABASE_URL=postgresql+asyncpg://printo:printo@db:5432/printo

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=60

# SMS
SMS_PROVIDER=stub
SMS_CODE_TTL_SECONDS=300
SMS_RATE_LIMIT_PER_MIN=2
SMS_MAX_ATTEMPTS=5

# Storage (S3 / MinIO compatible)
S3_ENDPOINT_URL=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minio
S3_SECRET_KEY=miniominio
S3_BUCKET=printo-files
S3_PUBLIC_URL_BASE=http://localhost:9000/printo-files

# Files
FILE_MAX_SIZE_MB=25
FILE_ALLOWED_EXT=pdf,doc,docx,png,jpg,jpeg

# Pricing (KZT per copy)
PRICE_BW=90
PRICE_COLOR=180

# Payment
PAYMENT_PROVIDER=stub
PAYMENT_WEBHOOK_SECRET=change-me-webhook-secret
